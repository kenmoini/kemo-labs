TZ=America/New_York

# PostgreSQL connection (shared instance at 192.168.62.15)
DB_POSTGRESDB_DATABASE=n8n
DB_POSTGRESDB_USER=n8n
DB_POSTGRESDB_PASSWORD=changeme-secure-database-password

# CRITICAL: Encryption key for credentials stored in the database.
# Generate with: openssl rand -hex 32
# Back this up securely -- losing it makes all stored credentials unrecoverable.
N8N_ENCRYPTION_KEY=changeme-generate-and-backup-this-key
