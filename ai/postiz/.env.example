TZ=America/New_York

# JWT secret for Postiz session signing
# Generate with: openssl rand -hex 64
JWT_SECRET=changeme-generate-a-long-random-string

# Postiz PostgreSQL (shared instance at 192.168.62.15)
POSTIZ_DB_NAME=postiz
POSTIZ_DB_USER=postiz
POSTIZ_DB_PASSWORD=changeme-postiz-db-password

# Temporal PostgreSQL (co-deployed, separate from shared instance)
TEMPORAL_DB_USER=temporal
TEMPORAL_DB_PASSWORD=changeme-temporal-db-password

# Social media API keys (uncomment and configure as needed)
# X_API_KEY=
# X_API_SECRET=
# LINKEDIN_CLIENT_ID=
# LINKEDIN_CLIENT_SECRET=
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=
# FACEBOOK_APP_ID=
# FACEBOOK_APP_SECRET=
# YOUTUBE_CLIENT_ID=
# YOUTUBE_CLIENT_SECRET=
# TIKTOK_CLIENT_ID=
# TIKTOK_CLIENT_SECRET=
# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=
# DISCORD_BOT_TOKEN_ID=

# Optional: AI content generation (local Ollama or OpenAI)
# OPENAI_API_KEY=
