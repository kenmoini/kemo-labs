TZ=America/New_York

# PostgreSQL connection (shared instance at 192.168.62.15)
SHLINK_DB_NAME=shlink
SHLINK_DB_USER=shlink
SHLINK_DB_PASSWORD=changeme-shlink-db-password

# Shlink API key (generated after first start via: docker exec shlink shlink api-key:generate)
# Set this after initial deployment to pre-configure the web client
SHLINK_API_KEY=

# Optional: MaxMind GeoLite2 license key for IP geolocation
# Register at https://www.maxmind.com/en/geolite2/signup
# GEOLITE_LICENSE_KEY=
