# =============================================================================
# Shared Databases Stack - Environment Variables
# =============================================================================
# Copy this file to .env and replace all placeholder values.
#   cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# MariaDB
# -----------------------------------------------------------------------------
MYSQL_ROOT_PASSWORD=changeme_mariadb_root
MYSQL_DATABASE=default_db
MYSQL_USER=mariadb_admin
MYSQL_PASSWORD=changeme_mariadb_admin
MYSQL_GITLAB_PASSWORD=changeme_gitlab_mariadb
MYSQL_MAILCOW_PASSWORD=changeme_mailcow_mariadb

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_postgres_root
PG_AUTHENTIK_PASSWORD=changeme_authentik_pg
PG_GITLAB_PASSWORD=changeme_gitlab_pg
PG_NETBOX_PASSWORD=changeme_netbox_pg
PG_PAPERLESS_PASSWORD=changeme_paperless_pg
PG_N8N_PASSWORD=changeme_n8n_pg
PG_POSTIZ_PASSWORD=changeme_postiz_pg
PG_SHLINK_PASSWORD=changeme_shlink_pg
PG_AFFINE_PASSWORD=changeme_affine_pg
PG_SEMAPHORE_PASSWORD=changeme_semaphore_pg

# -----------------------------------------------------------------------------
# Valkey (Redis-compatible)
# -----------------------------------------------------------------------------
VALKEY_PASSWORD=changeme_valkey

# -----------------------------------------------------------------------------
# MQTT (Mosquitto)
# -----------------------------------------------------------------------------
MQTT_USER=homeassistant
MQTT_PASSWORD=changeme_mqtt

# -----------------------------------------------------------------------------
# Databasus (Backups)
# -----------------------------------------------------------------------------
DATABASUS_CRON_SCHEDULE=0 2 * * *
DATABASUS_RETENTION_DAYS=30
