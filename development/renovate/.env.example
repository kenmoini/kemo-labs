# Renovate Bot Configuration
# Copy to .env and fill in values

# GitLab personal access token (api, read_user, read_repository, write_repository scopes)
RENOVATE_TOKEN=changeme

# Auto-discover all repos or filter
RENOVATE_AUTODISCOVER=true
RENOVATE_AUTODISCOVER_FILTER=*/*

# Log level: debug, info, warn, error
LOG_LEVEL=info

# Timezone
TZ=America/New_York
