# Netbox Configuration
# Copy to .env and fill in values

# PostgreSQL credentials for shared instance
DB_NAME=netbox
DB_USER=netbox
DB_PASSWORD=changeme

# Valkey/Redis password (leave empty if no auth)
REDIS_PASSWORD=

# Django secret key (generate with: python3 -c "import secrets; print(secrets.token_urlsafe(50))")
SECRET_KEY=changeme

# Initial superuser (only used on first boot)
SKIP_SUPERUSER=false
SUPERUSER_NAME=admin
SUPERUSER_EMAIL=admin@lab.kemo.dev
SUPERUSER_PASSWORD=changeme
SUPERUSER_API_TOKEN=

# Timezone
TZ=America/New_York
