# Paperless-AI Configuration
# Copy to .env and fill in values

# Paperless-NGX API connection
PAPERLESS_API_URL=https://paperless.lab.kemo.dev/api
PAPERLESS_API_TOKEN=changeme
PAPERLESS_USERNAME=admin

# AI Provider: ollama, openai, or custom
AI_PROVIDER=ollama

# Ollama settings (when AI_PROVIDER=ollama)
OLLAMA_API_URL=http://192.168.62.70:11434
OLLAMA_MODEL=llama3.2

# OpenAI settings (when AI_PROVIDER=openai)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Custom OpenAI-compatible API (when AI_PROVIDER=custom)
# CUSTOM_BASE_URL=
# CUSTOM_API_KEY=
# CUSTOM_MODEL=

# Document processing
SCAN_INTERVAL=*/30 * * * *
PROCESS_PREDEFINED_DOCUMENTS=yes
TAGS=pre-process
ADD_AI_PROCESSED_TAG=yes
AI_PROCESSED_TAG_NAME=ai-processed

# Set to yes on first run, then change to no
PAPERLESS_AI_INITIAL_SETUP=yes

# Process user/group IDs
PUID=1000
PGID=1000

# Timezone
TZ=America/New_York
