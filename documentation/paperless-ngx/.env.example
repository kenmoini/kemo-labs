# Paperless-NGX Configuration
# Copy to .env and fill in values

# Django secret key (generate with: python3 -c "import secrets; print(secrets.token_urlsafe(50))")
PAPERLESS_SECRET_KEY=changeme

# Initial admin user (only used on first boot)
PAPERLESS_ADMIN_USER=admin
PAPERLESS_ADMIN_PASSWORD=changeme
PAPERLESS_ADMIN_MAIL=admin@lab.kemo.dev

# PostgreSQL credentials for shared instance
PAPERLESS_DBNAME=paperless
PAPERLESS_DBUSER=paperless
PAPERLESS_DBPASS=changeme

# Valkey/Redis password (leave empty if no auth)
REDIS_PASSWORD=

# File ownership mapping
USERMAP_UID=1000
USERMAP_GID=1000

# Timezone
TZ=America/New_York
