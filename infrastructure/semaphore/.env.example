# Semaphore UI Configuration
# Copy to .env and fill in values

# PostgreSQL credentials for shared instance at 192.168.62.16
DB_USERNAME=semaphore
DB_PASSWORD=changeme
DB_DATABASE=semaphore

# Admin user (created on first run)
SEMAPHORE_ADMIN_NAME=Admin
SEMAPHORE_ADMIN_EMAIL=admin@lab.kemo.dev
SEMAPHORE_ADMIN=admin
SEMAPHORE_ADMIN_PASSWORD=changeme

# Encryption key for stored credentials (SSH keys, passwords in the DB)
# Generate with: openssl rand -hex 32
SEMAPHORE_ACCESS_KEY_ENCRYPTION=changeme

# LDAP integration (set to 'yes' to enable)
SEMAPHORE_LDAP_ACTIVATED=no

# Timezone
TZ=America/New_York
