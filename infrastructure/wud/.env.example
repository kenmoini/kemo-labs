# WUD (What's Up Docker) Configuration
# Copy this file to .env and adjust values as needed.

# Timezone
TZ=America/New_York

# Watcher configuration
# Cron schedule for checking updates (default: every 6 hours)
WUD_WATCHER_LOCAL_CRON=0 */6 * * *

# Monitor all containers by default (set to false to use opt-in via wud.watch=true label)
WUD_WATCHER_LOCAL_WATCHBYDEFAULT=true

# Ntfy trigger configuration
# URL of the Ntfy server
WUD_TRIGGER_NTFY_HOMELAB_URL=http://192.168.62.82

# Ntfy topic for update notifications
WUD_TRIGGER_NTFY_HOMELAB_TOPIC=wud

# Ntfy message priority (0=min, 3=default, 5=max)
WUD_TRIGGER_NTFY_HOMELAB_PRIORITY=3
