# Scrutiny - Environment Variables

# Static IP address
STATIC_IP=192.168.42.33

# Image tag (omnibus includes web + collector + InfluxDB)
SCRUTINY_TAG=v0.8.1-omnibus

# Domain for Traefik routing
SCRUTINY_DOMAIN=scrutiny.lab.kemo.dev

# S.M.A.R.T. collection schedule (cron format)
# Default: every 4 hours
COLLECTOR_CRON_SCHEDULE=0 */4 * * *
