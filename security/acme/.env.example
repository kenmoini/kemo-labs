# StepCA Configuration
# These variables are used on first init only. After initialization,
# configuration is managed via /home/step/config/ca.json inside the volume.
DOCKER_STEPCA_INIT_NAME=Homelab CA
DOCKER_STEPCA_INIT_DNS_NAMES=acme.lab.kemo.dev,192.168.62.6
DOCKER_STEPCA_INIT_REMOTE_MANAGEMENT=true
DOCKER_STEPCA_INIT_ACME=true

# Password used to encrypt CA keys during initialization
# Generate with: openssl rand -hex 24
DOCKER_STEPCA_INIT_PASSWORD=changeme-generate-a-strong-password
