# Authentik Configuration

# Generate with: openssl rand -hex 50
AUTHENTIK_SECRET_KEY=changeme-generate-a-strong-secret-key

# PostgreSQL (shared instance at 192.168.62.15)
AUTHENTIK_POSTGRESQL__HOST=192.168.62.15
AUTHENTIK_POSTGRESQL__PORT=5432
AUTHENTIK_POSTGRESQL__NAME=authentik
AUTHENTIK_POSTGRESQL__USER=authentik
AUTHENTIK_POSTGRESQL__PASSWORD=changeme-set-db-password

# Valkey/Redis (shared instance at 192.168.62.15)
AUTHENTIK_REDIS__HOST=192.168.62.15
AUTHENTIK_REDIS__PORT=6379
AUTHENTIK_REDIS__DB=4

# Logging and telemetry
AUTHENTIK_ERROR_REPORTING__ENABLED=false
AUTHENTIK_LOG_LEVEL=info

# Email (optional - configure when Mailcow is available)
# AUTHENTIK_EMAIL__HOST=192.168.62.80
# AUTHENTIK_EMAIL__PORT=587
# AUTHENTIK_EMAIL__FROM=auth@lab.kemo.dev
# AUTHENTIK_EMAIL__USERNAME=auth@lab.kemo.dev
# AUTHENTIK_EMAIL__PASSWORD=changeme
# AUTHENTIK_EMAIL__USE_TLS=true
